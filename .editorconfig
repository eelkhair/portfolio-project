# Top-most EditorConfig file
root = true

# All files
[*]
charset = utf-8
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

# C# files
[*.cs]
indent_size = 4

# Use 'var' when apparent
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = true:suggestion

# Expression-bodied members
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_constructors = false:suggestion
csharp_style_expression_bodied_properties = true:suggestion
csharp_style_expression_bodied_accessors = true:suggestion

# Pattern matching
csharp_style_pattern_matching_over_is_with_cast_check = true:suggestion
csharp_style_pattern_matching_over_as_with_null_check = true:suggestion

# File-scoped namespaces
csharp_style_namespace_declarations = file_scoped:suggestion

# Using directives
dotnet_sort_system_directives_first = true

# Naming: private fields use _camelCase
dotnet_naming_rule.private_fields_should_be_camel_case.severity = suggestion
dotnet_naming_rule.private_fields_should_be_camel_case.symbols = private_fields
dotnet_naming_rule.private_fields_should_be_camel_case.style = camel_case_underscore

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private

dotnet_naming_style.camel_case_underscore.required_prefix = _
dotnet_naming_style.camel_case_underscore.capitalization = camel_case

# Naming: async methods end with Async
dotnet_naming_rule.async_methods_should_end_with_async.severity = suggestion
dotnet_naming_rule.async_methods_should_end_with_async.symbols = async_methods
dotnet_naming_rule.async_methods_should_end_with_async.style = async_suffix

dotnet_naming_symbols.async_methods.applicable_kinds = method
dotnet_naming_symbols.async_methods.required_modifiers = async

dotnet_naming_style.async_suffix.required_suffix = Async
dotnet_naming_style.async_suffix.capitalization = pascal_case

# IDE rules
dotnet_diagnostic.IDE0005.severity = warning
dotnet_diagnostic.IDE0055.severity = warning
dotnet_diagnostic.IDE0161.severity = suggestion

# Naming rules — suggestion to avoid inflating warning count
dotnet_diagnostic.IDE1006.severity = suggestion

# Suppress noisy rules
# MA0004: Use ConfigureAwait — not needed in ASP.NET Core
dotnet_diagnostic.MA0004.severity = none
# MA0048: File name must match type name
dotnet_diagnostic.MA0048.severity = suggestion
# MA0002: Use overload with IEqualityComparer/IComparer — suggestion only
dotnet_diagnostic.MA0002.severity = suggestion
# MA0011: Use overload with CultureInfo — suggestion only
dotnet_diagnostic.MA0011.severity = suggestion
# MA0016: Prefer collection abstraction — suggestion only
dotnet_diagnostic.MA0016.severity = suggestion
# MA0009: Regex DoS vulnerability — suggestion only
dotnet_diagnostic.MA0009.severity = suggestion
# MA0100: Await task before disposing — suggestion only
dotnet_diagnostic.MA0100.severity = suggestion
# MA0015: Use overload with parameter name — suggestion only
dotnet_diagnostic.MA0015.severity = suggestion
# MA0025: Implement the functionality — suggestion only
dotnet_diagnostic.MA0025.severity = suggestion
# MA0047: Declare type in namespace — suggestion only
dotnet_diagnostic.MA0047.severity = suggestion
# MA0134: Observe result of async calls — suggestion only
dotnet_diagnostic.MA0134.severity = suggestion
# MA0026: TODO/FIXME/HACK comments — suggestion only
dotnet_diagnostic.MA0026.severity = suggestion
# CA2254: Logging message template should not vary — suggestion only
dotnet_diagnostic.CA2254.severity = suggestion
# MA0051: Method is too long
dotnet_diagnostic.MA0051.severity = suggestion

# CA1062: Validate arguments of public methods — redundant with nullable reference types
dotnet_diagnostic.CA1062.severity = none
# CA1848: Use LoggerMessage delegates — good practice but verbose for portfolio
dotnet_diagnostic.CA1848.severity = suggestion
# CA1873: Expensive argument evaluation in logging — same category as CA1848
dotnet_diagnostic.CA1873.severity = suggestion
# CA1054/CA1055/CA1056: URI properties/params/returns should not be strings
dotnet_diagnostic.CA1054.severity = suggestion
dotnet_diagnostic.CA1055.severity = suggestion
dotnet_diagnostic.CA1056.severity = suggestion

# CA1707: Identifiers should not contain underscores — test methods use underscores by convention
dotnet_diagnostic.CA1707.severity = suggestion
# CA1305: Specify IFormatProvider
dotnet_diagnostic.CA1305.severity = suggestion
# CA1311: Specify culture for string operations
dotnet_diagnostic.CA1311.severity = suggestion
# CA1304: Specify CultureInfo
dotnet_diagnostic.CA1304.severity = suggestion
# CA1716: Identifiers should not match keywords
dotnet_diagnostic.CA1716.severity = suggestion
# CA1816: Call GC.SuppressFinalize correctly
dotnet_diagnostic.CA1816.severity = suggestion
# CS1591: Missing XML comment — not required for portfolio
dotnet_diagnostic.CS1591.severity = none

# Test projects — relax certain rules
[*Tests/**/*.cs]
dotnet_diagnostic.CA1707.severity = none
dotnet_diagnostic.MA0051.severity = none
dotnet_diagnostic.CA1848.severity = none
dotnet_diagnostic.CA2254.severity = none

[*.test*/**/*.cs]
dotnet_diagnostic.CA1707.severity = none
dotnet_diagnostic.MA0051.severity = none
dotnet_diagnostic.CA1848.severity = none
dotnet_diagnostic.CA2254.severity = none

[*.Tests/**/*.cs]
dotnet_diagnostic.CA1707.severity = none
dotnet_diagnostic.MA0051.severity = none
dotnet_diagnostic.CA1848.severity = none
dotnet_diagnostic.CA2254.severity = none
