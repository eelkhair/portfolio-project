# Mirror the local-dev behavior in CI. `@cloudflare/next-on-pages` declares
# `vercel` and `next` as peer deps with tight ranges that npm 7+ auto-installs
# by default. That pulls in ~50 @vercel/* packages we don't actually use,
# massively bloating the lockfile. `legacy-peer-deps=true` keeps the install
# tree lean — the Vercel CLI is only needed inside @cloudflare/next-on-pages'
# own build pipeline, which ships its own vendored copy.
legacy-peer-deps=true
