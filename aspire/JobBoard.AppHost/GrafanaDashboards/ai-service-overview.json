{
  "uid": "jobboard-ai-service",
  "title": "JobBoard — AI Service Overview",
  "tags": ["jobboard", "ai-service"],
  "timezone": "browser",
  "editable": true,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "environment",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "query": "label_values(ai_chat_request_count_total, deployment_environment)",
        "refresh": 2,
        "includeAll": true,
        "multi": false,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "scope",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "query": "label_values(ai_chat_request_count_total{deployment_environment=~\"$environment\"}, ai_chat_scope)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "provider",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "query": "label_values(ai_chat_request_count_total{deployment_environment=~\"$environment\"}, ai_provider)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Chat Requests Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(increase(ai_chat_request_count_total{deployment_environment=~\"$environment\",ai_chat_scope=~\"$scope\",ai_provider=~\"$provider\"}[1m])) by (ai_chat_scope, ai_provider)",
          "legendFormat": "{{ai_chat_scope}} / {{ai_provider}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "fillOpacity": 50, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "id": 5,
      "title": "Total Chat Requests",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(ai_chat_request_count_total{deployment_environment=~\"$environment\",ai_chat_scope=~\"$scope\"})",
          "legendFormat": "requests"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 4,
      "title": "Total Tokens",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(ai_chat_tokens_prompt_total{deployment_environment=~\"$environment\"}) + sum(ai_chat_tokens_completion_total{deployment_environment=~\"$environment\"})",
          "legendFormat": "total tokens"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 3,
      "title": "Token Usage Over Time — Prompt vs Completion",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(increase(ai_chat_tokens_prompt_total{deployment_environment=~\"$environment\",ai_chat_scope=~\"$scope\",ai_provider=~\"$provider\"}[1m])) by (ai_provider)",
          "legendFormat": "prompt — {{ai_provider}}"
        },
        {
          "expr": "sum(increase(ai_chat_tokens_completion_total{deployment_environment=~\"$environment\",ai_chat_scope=~\"$scope\",ai_provider=~\"$provider\"}[1m])) by (ai_provider)",
          "legendFormat": "completion — {{ai_provider}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "fillOpacity": 50, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "id": 6,
      "title": "Tool Calls Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(increase(ai_tool_call_count_total{deployment_environment=~\"$environment\",ai_chat_scope=~\"$scope\"}[1m])) by (ai_tool_name)",
          "legendFormat": "{{ai_tool_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "id": 7,
      "title": "Embeddings Generated (total)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(ai_embeddings_generated_count_total{deployment_environment=~\"$environment\"}) or vector(0)",
          "legendFormat": "embeddings"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 8,
      "title": "Resumes Parsed (total)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(ai_resumes_parsed_count_total{deployment_environment=~\"$environment\"}) or vector(0)",
          "legendFormat": "parsed"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 10,
      "title": "Resume Parse Failures (total)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(ai_resumes_parse_failed_count_total{deployment_environment=~\"$environment\"}) or vector(0)",
          "legendFormat": "failures"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      }
    },
    {
      "id": 9,
      "title": "CQRS Commands Over Time (AI Service)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 18, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(increase(cqrs_command_success_count_total{deployment_environment=~\"$environment\",service_name=\"JobBoard.AI\"}[1m])) by (command_name)",
          "legendFormat": "{{command_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "fillOpacity": 50, "stacking": { "mode": "normal" } }
        }
      }
    }
  ],
  "schemaVersion": 39
}
