{
  "uid": "jobboard-ai-service",
  "title": "JobBoard — AI Service Overview",
  "tags": ["jobboard", "ai-service"],
  "timezone": "browser",
  "editable": true,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "environment",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "query": "label_values(ai_chat_request_count_total, deployment_environment)",
        "refresh": 2,
        "includeAll": true,
        "multi": false,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "scope",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "query": "label_values(ai_chat_request_count_total{deployment_environment=~\"$environment\"}, ai_chat_scope)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "provider",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "query": "label_values(ai_chat_request_count_total{deployment_environment=~\"$environment\"}, ai_provider)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Chat Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(rate(ai_chat_request_count_total{deployment_environment=~\"$environment\",ai_chat_scope=~\"$scope\",ai_provider=~\"$provider\"}[1m])) by (ai_chat_scope, ai_provider)",
          "legendFormat": "{{ai_chat_scope}} / {{ai_provider}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 15 }
        }
      }
    },
    {
      "id": 2,
      "title": "Chat Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(ai_chat_duration_bucket{deployment_environment=~\"$environment\",ai_chat_scope=~\"$scope\",ai_provider=~\"$provider\"}[5m])) by (le, ai_provider))",
          "legendFormat": "p50 {{ai_provider}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(ai_chat_duration_bucket{deployment_environment=~\"$environment\",ai_chat_scope=~\"$scope\",ai_provider=~\"$provider\"}[5m])) by (le, ai_provider))",
          "legendFormat": "p95 {{ai_provider}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(ai_chat_duration_bucket{deployment_environment=~\"$environment\",ai_chat_scope=~\"$scope\",ai_provider=~\"$provider\"}[5m])) by (le, ai_provider))",
          "legendFormat": "p99 {{ai_provider}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "fillOpacity": 5 }
        }
      }
    },
    {
      "id": 3,
      "title": "Token Usage — Prompt vs Completion",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(rate(ai_chat_tokens_prompt_total{deployment_environment=~\"$environment\",ai_chat_scope=~\"$scope\",ai_provider=~\"$provider\"}[1m])) by (ai_provider)",
          "legendFormat": "prompt — {{ai_provider}}"
        },
        {
          "expr": "sum(rate(ai_chat_tokens_completion_total{deployment_environment=~\"$environment\",ai_chat_scope=~\"$scope\",ai_provider=~\"$provider\"}[1m])) by (ai_provider)",
          "legendFormat": "completion — {{ai_provider}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "id": 4,
      "title": "Total Tokens (cumulative)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(ai_chat_tokens_prompt_total) + sum(ai_chat_tokens_completion_total)",
          "legendFormat": "total tokens"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 5,
      "title": "Total Chat Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(ai_chat_request_count_total{deployment_environment=~\"$environment\",ai_chat_scope=~\"$scope\"})",
          "legendFormat": "requests"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 6,
      "title": "Tool Call Frequency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(rate(ai_tool_call_count_total{deployment_environment=~\"$environment\",ai_chat_scope=~\"$scope\"}[1m])) by (ai_tool_name)",
          "legendFormat": "{{ai_tool_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "id": 7,
      "title": "Embedding Generation Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(ai_embedding_duration_bucket{deployment_environment=~\"$environment\"}[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(ai_embedding_duration_bucket{deployment_environment=~\"$environment\"}[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(ai_embedding_duration_bucket{deployment_environment=~\"$environment\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 8,
      "title": "Resume Parse Pipeline Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(ai_resume_parse_duration_bucket{deployment_environment=~\"$environment\"}[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(ai_resume_parse_duration_bucket{deployment_environment=~\"$environment\"}[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(ai_resume_parse_duration_bucket{deployment_environment=~\"$environment\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 9,
      "title": "CQRS Command Rate (AI Service)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(rate(cqrs_command_success_count_total{deployment_environment=~\"$environment\",service_name=\"JobBoard.AI\"}[1m])) by (command_name)",
          "legendFormat": "{{command_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "bars", "fillOpacity": 50, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "id": 10,
      "title": "CQRS Command Duration (AI Service)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(cqrs_command_duration_bucket{deployment_environment=~\"$environment\",service_name=\"JobBoard.AI\"}[5m])) by (le, command_name))",
          "legendFormat": "p95 {{command_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "fillOpacity": 5 }
        }
      }
    }
  ],
  "schemaVersion": 39
}
