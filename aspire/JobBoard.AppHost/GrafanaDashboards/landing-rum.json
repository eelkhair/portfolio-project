{
  "uid": "jobboard-landing-rum",
  "title": "JobBoard \u2014 Landing Page RUM",
  "tags": ["jobboard", "landing", "rum", "faro"],
  "timezone": "browser",
  "editable": true,
  "refresh": "30s",
  "schemaVersion": 39,
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "environment",
        "label": "Environment",
        "type": "custom",
        "query": "local",
        "options": [
          { "selected": true, "text": "local", "value": "local" }
        ],
        "includeAll": false,
        "multi": false,
        "current": { "text": "local", "value": "local" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Page loads (1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "sum(increase(traces_span_metrics_calls_total{service_name=\"landing\", deployment_environment=~\"$environment\"}[1h]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "decimals": 0
        }
      }
    },
    {
      "id": 2,
      "title": "Errors (1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "sum(increase(traces_span_metrics_calls_total{service_name=\"landing\", status_code=\"STATUS_CODE_ERROR\", deployment_environment=~\"$environment\"}[1h])) or vector(0)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "decimals": 0
        }
      }
    },
    {
      "id": 3,
      "title": "p95 latency",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(traces_span_metrics_duration_milliseconds_bucket{service_name=\"landing\", deployment_environment=~\"$environment\"}[5m])))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Throughput (req/s)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "sum(rate(traces_span_metrics_calls_total{service_name=\"landing\", deployment_environment=~\"$environment\"}[5m]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Span rate by name (top 10)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "topk(10, sum by (span_name) (rate(traces_span_metrics_calls_total{service_name=\"landing\", deployment_environment=~\"$environment\"}[5m])))",
          "legendFormat": "{{span_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Latency p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(traces_span_metrics_duration_milliseconds_bucket{service_name=\"landing\", deployment_environment=~\"$environment\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(traces_span_metrics_duration_milliseconds_bucket{service_name=\"landing\", deployment_environment=~\"$environment\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(traces_span_metrics_duration_milliseconds_bucket{service_name=\"landing\", deployment_environment=~\"$environment\"}[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 5
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Error rate by route",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "sum by (span_name) (rate(traces_span_metrics_calls_total{service_name=\"landing\", status_code=\"STATUS_CODE_ERROR\", deployment_environment=~\"$environment\"}[5m]))",
          "legendFormat": "{{span_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Top routes (1h)",
      "type": "table",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "topk(10, sum by (span_name) (increase(traces_span_metrics_calls_total{service_name=\"landing\", deployment_environment=~\"$environment\"}[1h])))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": { "Value": "Hits", "span_name": "Span" }
          }
        }
      ]
    },
    {
      "id": 10,
      "title": "Top countries (1h)",
      "type": "table",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "topk(20, sum by (geo_country_code) (increase(traces_span_metrics_calls_total{service_name=\"landing\", deployment_environment=~\"$environment\"}[1h])))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": { "Value": "Hits", "geo_country_code": "Country" }
          }
        }
      ]
    },
    {
      "id": 11,
      "title": "Visitors by country",
      "type": "geomap",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "sum by (geo_country_code) (increase(traces_span_metrics_calls_total{service_name=\"landing\", deployment_environment=~\"$environment\"}[1h]))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": { "Value": "Hits", "geo_country_code": "country" }
          }
        }
      ],
      "options": {
        "view": { "id": "zero", "lat": 20, "lon": 0, "zoom": 1.5 },
        "controls": { "showZoom": true, "mouseWheelZoom": true, "showAttribution": true },
        "basemap": { "type": "default" },
        "layers": [
          {
            "type": "markers",
            "name": "Visitors",
            "config": {
              "style": {
                "color": { "fixed": "blue" },
                "opacity": 0.6,
                "size": { "field": "Hits", "fixed": 5, "min": 4, "max": 30 }
              },
              "showLegend": true
            },
            "location": { "mode": "lookup", "lookup": "country", "gazetteer": "public/gazetteer/countries.json" }
          }
        ]
      }
    },
    {
      "id": 13,
      "title": "Visitors by city",
      "type": "geomap",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 31 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "sum by (geo_city, geo_country_code, geo_lat, geo_lon) (increase(traces_span_metrics_calls_total{service_name=\"landing\", deployment_environment=~\"$environment\", geo_city!=\"\", geo_lat!=\"\"}[1h]))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": {
              "Value": "Hits",
              "geo_city": "city",
              "geo_country_code": "country",
              "geo_lat": "lat",
              "geo_lon": "lon"
            }
          }
        },
        {
          "id": "convertFieldType",
          "options": {
            "conversions": [
              { "targetField": "lat", "destinationType": "number" },
              { "targetField": "lon", "destinationType": "number" }
            ]
          }
        }
      ],
      "options": {
        "view": { "id": "zero", "lat": 20, "lon": 0, "zoom": 1.5 },
        "controls": { "showZoom": true, "mouseWheelZoom": true, "showAttribution": true },
        "basemap": { "type": "default" },
        "layers": [
          {
            "type": "markers",
            "name": "Cities",
            "config": {
              "style": {
                "color": { "fixed": "orange" },
                "opacity": 0.7,
                "size": { "field": "Hits", "fixed": 6, "min": 4, "max": 30 },
                "textConfig": { "fontSize": 11, "offsetY": -14, "textAlign": "center", "textBaseline": "alphabetic" },
                "text": { "field": "city", "fixed": "" }
              },
              "showLegend": true
            },
            "location": { "mode": "coords", "latitude": "lat", "longitude": "lon" }
          }
        ]
      }
    },
    {
      "id": 12,
      "title": "Top cities (1h)",
      "type": "table",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 43 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "topk(20, sum by (geo_country_code, geo_region, geo_city) (increase(traces_span_metrics_calls_total{service_name=\"landing\", deployment_environment=~\"$environment\", geo_city!=\"\"}[1h])))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": {
              "Value": "Hits",
              "geo_country_code": "Country",
              "geo_region": "Region",
              "geo_city": "City"
            },
            "indexByName": { "geo_city": 0, "geo_region": 1, "geo_country_code": 2, "Value": 3 }
          }
        }
      ]
    },
    {
      "id": 9,
      "title": "Recent traces (last 25)",
      "type": "table",
      "gridPos": { "h": 11, "w": 24, "x": 0, "y": 52 },
      "datasource": { "type": "jaeger", "uid": "jaeger" },
      "targets": [
        {
          "datasource": { "type": "jaeger", "uid": "jaeger" },
          "queryType": "search",
          "service": "landing",
          "limit": 25,
          "refId": "A"
        }
      ]
    }
  ]
}
