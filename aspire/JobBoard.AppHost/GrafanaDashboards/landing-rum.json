            "uid": "infinity-jaeger"
          },
          "filterExpression": "'${city:raw}' == '' || city == '${city:raw}'",
          "format": "table",
          "parser": "backend",
          "refId": "A",
          "root_selector": "($m := data.spans[tags[key='geo.country_code'] and tags[key='http.url'] and $not($contains($string(tags[key='http.url'][0].value), '/cdn-cgi'))]; $exists($m) ? $m.{\"traceID\": $string(traceID),\"operationName\": $string(operationName),\"startTime\": startTime,\"duration\": duration,\"route\": $string($replace($replace($string(tags[key='http.url'][0].value), /^https?:\\/\\/[^\\/]+/, \"\"), /\\?.*$/, \"\")),\"city\": $string(tags[key='geo.city'][0].value),\"region\": $string(tags[key='geo.region'][0].value),\"country\": $string(tags[key='geo.country_code'][0].value)} : [])",
          "source": "url",
          "type": "json",
          "url": "/api/traces?service=$service&tags=%7B%22deployment.environment%22%3A%22$environment%22%7D&limit=2000&start=${__from}000&end=${__to}000",
          "url_options": {
            "data": "",
            "method": "GET"
          }
        }
      ],
      "title": "Recent traces",
      "transformations": [
        {
          "id": "calculateField",
          "options": {
            "alias": "Started",
            "binary": {
              "left": "Start",
              "operator": "/",
              "right": "1000"
            },
            "mode": "binary",
            "replaceFields": false
          }
        },
        {
          "id": "calculateField",
          "options": {
            "alias": "Duration (ms)",
            "binary": {
              "left": "Duration",
              "operator": "/",
              "right": "1000"
            },
            "mode": "binary",
            "replaceFields": false
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Duration": true,
