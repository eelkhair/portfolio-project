{
  "uid": "jobboard-monolith",
  "title": "JobBoard — Monolith Overview",
  "tags": ["jobboard", "monolith"],
  "timezone": "browser",
  "editable": true,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "environment",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "query": "label_values(cqrs_command_success_count_total, deployment_environment)",
        "refresh": 2,
        "includeAll": true,
        "multi": false,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "command",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "query": "label_values(cqrs_command_success_count_total{deployment_environment=~\"$environment\"}, command_name)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_count_total{deployment_environment=~\"$environment\"}[1m])) by (http_route, http_request_method)",
          "legendFormat": "{{http_request_method}} {{http_route}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 2,
      "title": "HTTP Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_request_duration_bucket{deployment_environment=~\"$environment\",deployment_environment=~\"$environment\"}[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_bucket{deployment_environment=~\"$environment\",deployment_environment=~\"$environment\"}[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_request_duration_bucket{deployment_environment=~\"$environment\",deployment_environment=~\"$environment\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "fillOpacity": 5 }
        }
      }
    },
    {
      "id": 3,
      "title": "HTTP Error Rate (4xx / 5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_count_total{deployment_environment=~\"$environment\",http_response_status_code=~\"4..\"}[1m]))",
          "legendFormat": "4xx"
        },
        {
          "expr": "sum(rate(http_server_request_count_total{deployment_environment=~\"$environment\",http_response_status_code=~\"5..\"}[1m]))",
          "legendFormat": "5xx"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 15 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "5xx" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "4xx" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "id": 4,
      "title": "CQRS Command Execution Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(rate(cqrs_command_success_count_total{command_name=~\"$command\"}[1m])) by (command_name)",
          "legendFormat": "{{command_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "bars", "fillOpacity": 50, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "id": 5,
      "title": "CQRS Command Duration (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(cqrs_command_duration_bucket{deployment_environment=~\"$environment\",command_name=~\"$command\"}[5m])) by (le, command_name))",
          "legendFormat": "p50 {{command_name}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(cqrs_command_duration_bucket{deployment_environment=~\"$environment\",command_name=~\"$command\"}[5m])) by (le, command_name))",
          "legendFormat": "p95 {{command_name}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(cqrs_command_duration_bucket{deployment_environment=~\"$environment\",command_name=~\"$command\"}[5m])) by (le, command_name))",
          "legendFormat": "p99 {{command_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "fillOpacity": 5 }
        }
      }
    },
    {
      "id": 6,
      "title": "CQRS Failure Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(rate(cqrs_command_failure_count_total{deployment_environment=~\"$environment\",command_name=~\"$command\"}[1m])) by (command_name)",
          "legendFormat": "{{command_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "A" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "id": 7,
      "title": "Validation Failures",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(rate(cqrs_validation_failure_count_total{deployment_environment=~\"$environment\"}[1m])) by (command_name)",
          "legendFormat": "{{command_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "bars", "fillOpacity": 50 }
        }
      }
    },
    {
      "id": 8,
      "title": "Outbox Messages Processed / sec",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "rate(outbox_messages_processed_count_total{deployment_environment=~\"$environment\"}[1m])",
          "legendFormat": "processed/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "id": 9,
      "title": "Dead-Letter Messages (total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "deadletter_messages_found_count_total{deployment_environment=~\"$environment\"}",
          "legendFormat": "dead letters"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 10,
      "title": "Outbox Processed Over Time",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "rate(outbox_messages_processed_count_total{deployment_environment=~\"$environment\"}[1m])",
          "legendFormat": "processed/s"
        },
        {
          "expr": "rate(deadletter_messages_found_count_total[1m])",
          "legendFormat": "dead-letter/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    }
  ],
  "schemaVersion": 39
}
