{
  "uid": "jobboard-monolith",
  "title": "JobBoard — Monolith Overview",
  "tags": ["jobboard", "monolith"],
  "timezone": "browser",
  "editable": true,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "environment",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "query": "label_values(cqrs_command_success_count_total, deployment_environment)",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "current": { "text": "prod", "value": "prod" }
      },
      {
        "name": "command",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "query": "label_values(cqrs_command_success_count_total{deployment_environment=~\"$environment\"}, command_name)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Requests Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(increase(http_server_request_duration_seconds_count{deployment_environment=~\"$environment\",http_route!=\"/healthzEndpoint\"}[1m])) by (http_request_method)",
          "legendFormat": "{{http_request_method}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "fillOpacity": 50, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "id": 2,
      "title": "Total HTTP Requests",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(http_server_request_duration_seconds_count{deployment_environment=~\"$environment\",http_route!=\"/healthzEndpoint\"})",
          "legendFormat": "requests"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 3,
      "title": "HTTP Errors (total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(http_server_request_duration_seconds_count{deployment_environment=~\"$environment\",http_response_status_code=~\"4..\",http_route!=\"/healthzEndpoint\"}) or vector(0)",
          "legendFormat": "4xx"
        },
        {
          "expr": "sum(http_server_request_duration_seconds_count{deployment_environment=~\"$environment\",http_response_status_code=~\"5..\",http_route!=\"/healthzEndpoint\"}) or vector(0)",
          "legendFormat": "5xx"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 11,
      "title": "HTTP Errors Over Time",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(increase(http_server_request_duration_seconds_count{deployment_environment=~\"$environment\",http_response_status_code=~\"4..\",http_route!=\"/healthzEndpoint\"}[1m]))",
          "legendFormat": "4xx"
        },
        {
          "expr": "sum(increase(http_server_request_duration_seconds_count{deployment_environment=~\"$environment\",http_response_status_code=~\"5..\",http_route!=\"/healthzEndpoint\"}[1m]))",
          "legendFormat": "5xx"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "fillOpacity": 50 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "5xx" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "4xx" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "id": 8,
      "title": "Outbox Messages Processed (total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(outbox_messages_processed_count_total{deployment_environment=~\"$environment\"})",
          "legendFormat": "processed"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 9,
      "title": "Dead-Letter Messages (total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(deadletter_messages_found_count_total{deployment_environment=~\"$environment\"}) or vector(0)",
          "legendFormat": "dead letters"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 10,
      "title": "Outbox Processed Over Time",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(increase(outbox_messages_processed_count_total{deployment_environment=~\"$environment\"}[1m]))",
          "legendFormat": "processed"
        },
        {
          "expr": "sum(increase(deadletter_messages_found_count_total{deployment_environment=~\"$environment\"}[1m]))",
          "legendFormat": "dead-letter"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "fillOpacity": 50 }
        }
      }
    },
    {
      "id": 12,
      "title": "Recent Errors (click to open trace)",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "jaeger", "uid": "ef5fo1p8d0zcwd" },
      "targets": [
        {
          "queryType": "search",
          "service": "monolith-api",
          "tags": "error=true deployment.environment=$environment",
          "limit": 10
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Start time", "desc": true }]
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Trace ID" },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "View in Jaeger",
                    "url": "https://jaeger.eelkhair.net/trace/${__value.text}",
                    "targetBlank": true
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "id": 13,
      "title": "Recent Company Creations (click to open trace)",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "jaeger", "uid": "ef5fo1p8d0zcwd" },
      "targets": [
        {
          "queryType": "search",
          "service": "monolith-api",
          "operation": "CreateCompanyCommand.handle",
          "tags": "deployment.environment=$environment",
          "limit": 10
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Start time", "desc": true }]
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Trace ID" },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "View in Jaeger",
                    "url": "https://jaeger.eelkhair.net/trace/${__value.text}",
                    "targetBlank": true
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "id": 4,
      "title": "CQRS Commands Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(increase(cqrs_command_success_count_total{deployment_environment=~\"$environment\",command_name=~\"$command\"}[1m])) by (command_name)",
          "legendFormat": "{{command_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "fillOpacity": 50, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "id": 6,
      "title": "CQRS Failures Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(increase(cqrs_command_failure_count_total{deployment_environment=~\"$environment\",command_name=~\"$command\"}[1m])) by (command_name)",
          "legendFormat": "{{command_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "fillOpacity": 50 }
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "A" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "id": 7,
      "title": "Validation Failures Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(increase(cqrs_validation_failure_count_total{deployment_environment=~\"$environment\"}[1m])) by (command_name)",
          "legendFormat": "{{command_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "fillOpacity": 50 }
        }
      }
    }
  ],
  "schemaVersion": 39
}
