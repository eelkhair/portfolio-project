# watchdog config — copy to /opt/watchdog/config.env on the LXC (mode 0600).
# Never commit the populated version.

# --- Hosts ---------------------------------------------------------------
# Prod app VM IP (what the watchdog probes + SSHes to for L1).
PROD_HOST=192.168.1.112
# Dev app VM IP (poweroff target for L3).
DEV_HOST=192.168.1.200

# --- Proxmox API ---------------------------------------------------------
# Proxmox node name running the prod VM (from `pvesh get /cluster/resources`).
PROD_NODE=eelkhair2
# Numeric VMID of the prod VM on that node.
PROD_VMID=
# Proxmox API endpoint (host:port). Pick whichever node the LXC can reach;
# both cluster nodes expose the same API.
PVE_API_HOST=eelkhair2.lan:8006
# API token — created via `pveum` (see README). Never commit.
PVE_TOKEN_ID=watchdog@pve!auto-recovery
PVE_TOKEN_SECRET=

# --- SSH ----------------------------------------------------------------
SSH_USER=eelkhair
SSH_KEY=/opt/watchdog/.ssh/id_ed25519
COMPOSE_DIR=/home/eelkhair

# --- Probes -------------------------------------------------------------
# Space-separated URLs; all must return 2xx for "healthy".
# Defaults cover landing + gateway + monolith, which together prove the full
# request path.
# PROBE_URLS="http://192.168.1.112:6090/ http://192.168.1.112:5238/healthzEndpoint http://192.168.1.112:5280/healthzEndpoint"
PROBE_TIMEOUT=5

# --- Escalation cooldown ------------------------------------------------
# Seconds to wait after any action before escalating again.
COOLDOWN_SECS=300

# --- Uptime Kuma push ---------------------------------------------------
# Create a Push monitor in Kuma, paste the generated URL here. Leave empty
# to disable notifications (script still logs to journald).
# Example: https://uptime.eelkhair.net/api/push/abc123?status=up&msg=OK&ping=
KUMA_PUSH_URL=
