    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Keycloak": {
    "Authority": "http://localhost:9999/realms/job-board-local",
    "Audience": "job-board-api",
    "SwaggerClientId": "angular-admin",
