  },

  "OTEL_EXPORTER_ZIPKIN_ENDPOINT": "http://localhost:9411/api/v2/spans",

  "ConnectionStrings": {
    "UserDbContext": "Server=127.0.0.1,11433;Database=UserDb;User Id=sa;Password=YourStrong!Passw0rd;TrustServerCertificate=true"
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
